# Copy this file to .env and fill in real values.
# Never commit .env to version control.

# Port the Express server listens on
PORT=8080

# Base URL of the external MarketDataAPI.
# In dev/stage, point this at the companion mock:
#   FOREIGN_API_BASE_URL=http://market-data-provider-mock:3000
FOREIGN_API_BASE_URL=https://api.marketdata.com

# API key for authenticating with MarketDataAPI (required)
FOREIGN_API_KEY=your-market-data-api-key-here

# Comma-separated list of Kafka broker host:port pairs
KAFKA_BROKERS=localhost:9092

# Milliseconds between polling cycles
POLL_INTERVAL_MS=5000

# Comma-separated list of ticker symbols to poll
WATCHED_SYMBOLS=AAPL,MSFT,GOOGL,AMZN,TSLA
